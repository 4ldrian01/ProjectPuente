# ==============================================================
# ProjectPuente - Environment Variables
# ==============================================================
# COPY this file and rename to .env, then fill in your values.
# NEVER commit the .env file to version control.
# ==============================================================

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True

# Hosts / CORS / CSRF (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Keep this False in production and use CORS_ALLOWED_ORIGINS instead.
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional production security hardening
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database
# SQLite is configured in Django settings and stored at backend/db.sqlite3.
# No DB host/user/password variables are required for SQLite.

# ML Model Path (relative to project root)
ML_MODEL_PATH=ml_models/nllb-200-distilled-600M

# Strict offline simulation mode (recommended for Chapter 1-3 defense/evaluation).
# True  = disable online services like edge-tts endpoint usage.
# False = allow optional online services.
STRICT_OFFLINE_MODE=True

# Optional Edge TTS voice overrides
# Real voices verified with edge-tts 7.2.7:
#   en-US-EmmaMultilingualNeural
#   fil-PH-BlessicaNeural
#   fil-PH-AngeloNeural
#   es-ES-ElviraNeural
EDGE_TTS_VOICE_EN=en-US-EmmaMultilingualNeural
EDGE_TTS_VOICE_TL=fil-PH-BlessicaNeural
EDGE_TTS_VOICE_CBK=es-ES-ElviraNeural
EDGE_TTS_VOICE_HIL=fil-PH-BlessicaNeural
EDGE_TTS_VOICE_CEB=fil-PH-AngeloNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz
